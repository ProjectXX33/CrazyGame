# Crazy Game — Apache config for the pre-rendered React SPA
# Upload the contents of dist/ to your web root; this file ships with it.

<IfModule mod_rewrite.c>
  RewriteEngine On
  # If hosted in a subfolder, set RewriteBase accordingly (root = "/").
  RewriteBase /

  # ── Force HTTPS ────────────────────────────────────────────────────────────
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # ── Serve a pre-rendered route directly ────────────────────────────────────
  # /product/foo  ->  /product/foo/index.html  (no trailing-slash redirect)
  RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI}/index.html -f
  RewriteRule ^(.*)$ /$1/index.html [L]

  # ── Real files & directories are served as-is ──────────────────────────────
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # ── SPA fallback for everything else ───────────────────────────────────────
  RewriteRule ^ /index.html [L]
</IfModule>

# ── Compression ──────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript text/javascript application/json image/svg+xml application/xml
</IfModule>

# ── Caching ──────────────────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  # Hashed build assets are immutable — cache hard.
  <FilesMatch "\.(js|css|woff2?|png|jpe?g|gif|webp|svg|ico)$">
    ExpiresDefault "access plus 1 year"
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # HTML (incl. pre-rendered snapshots) must revalidate so content stays fresh.
  <FilesMatch "\.html$">
    ExpiresDefault "access plus 0 seconds"
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# Custom 404 → SPA shell (handles any route the rewrite missed)
ErrorDocument 404 /index.html
